RewriteEngine On

# This file is written to work in BOTH cases:
# 1) Backend is placed in domain root (routes are /api/...)
# 2) Backend is placed in /api folder (routes are /auth/login, /packages, ...)

# /api/auth/login OR /auth/login -> auth.php
RewriteRule ^(api/)?auth/login$ api/auth.php [L,QSA]

# /api/packages OR /packages -> packages.php
RewriteRule ^(api/)?packages$ api/packages.php [L,QSA]
RewriteRule ^(api/)?packages/([0-9]+)$ api/packages.php?id=$2 [L,QSA]

# /api/bookings OR /bookings -> bookings.php
RewriteRule ^(api/)?bookings$ api/bookings.php [L,QSA]
RewriteRule ^(api/)?bookings/([0-9]+)$ api/bookings.php?id=$2 [L,QSA]

# /api/blogs OR /blogs -> blogs.php
RewriteRule ^(api/)?blogs$ api/blogs.php [L,QSA]
RewriteRule ^(api/)?blogs/([0-9]+)$ api/blogs.php?id=$2 [L,QSA]
RewriteRule ^(api/)?blogs/slug/([^/]+)$ api/blogs.php?slug=$2 [L,QSA]

# /api/settings OR /settings -> settings.php
RewriteRule ^(api/)?settings$ api/settings.php [L,QSA]

# /api/upload OR /upload -> upload.php (multipart, admin JWT)
RewriteRule ^(api/)?upload$ api/upload.php [L,QSA]
