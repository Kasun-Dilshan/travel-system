{
  "name": "travel-business-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --prefix frontend",
    "build": "node scripts/build.js",
    "dist": "node scripts/dist.js",
    "php": "php -S localhost:8000 -t php-backend php-backend/router.php",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"npm run php\"",
    "frontend": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "rimraf": "^5.0.0"
  }
}
